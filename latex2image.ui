<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5" author="PygubuDesigner 0.41.4">
  <project>
    <settings />
    <customwidgets />
    <resources />
  </project>
  <object class="tk.Toplevel" id="toplevel1">
    <property name="height">200</property>
    <property name="minsize">450|320</property>
    <property name="padx">20</property>
    <property name="pady">20</property>
    <property name="title" translatable="yes">Latex2Image</property>
    <containerlayout manager="grid">
      <property name="anchor">center</property>
      <property type="col" id="0" name="weight">1</property>
      <property type="col" id="1" name="weight">1</property>
      <property type="row" id="3" name="weight">1</property>
    </containerlayout>
    <child>
      <object class="tk.Canvas" id="canvas1">
        <property name="background">#fff</property>
        <property name="height">120</property>
        <property name="width">300</property>
        <layout manager="grid">
          <property name="column">0</property>
          <property name="columnspan">2</property>
          <property name="row">3</property>
          <property name="sticky">nsew</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="ttk.Label" id="label1">
        <property name="text" translatable="yes">输入 Latex 公式</property>
        <layout manager="grid">
          <property name="column">0</property>
          <property name="columnspan">2</property>
          <property name="row">0</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="tk.Text" id="text1">
        <property name="background">#fff</property>
        <property name="height">5</property>
        <property name="width">50</property>
        <layout manager="grid">
          <property name="column">0</property>
          <property name="columnspan">2</property>
          <property name="row">1</property>
          <property name="sticky">ew</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="ttk.Button" id="button1">
        <property name="text" translatable="yes">转换</property>
        <bind sequence="&lt;1&gt;" handler="callback1" add="" />
        <layout manager="grid">
          <property name="column">0</property>
          <property name="pady">10</property>
          <property name="row">2</property>
        </layout>
      </object>
    </child>
    <child>
      <object class="ttk.Button" id="button2" named="True">
        <property name="text" translatable="yes">复制公式图片到剪贴板</property>
        <bind sequence="&lt;1&gt;" handler="callback2" add="" />
        <layout manager="grid">
          <property name="column">1</property>
          <property name="pady">10</property>
          <property name="row">2</property>
        </layout>
      </object>
    </child>
  </object>
</interface>
